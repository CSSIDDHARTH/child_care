    /* ====== Start Css Header ====== */
    .scolloff {
        overflow: hidden !important;
    }

    .box-header-2024-mb {
        display: none;
    }

    .header .box-header-2024 {
        background: #FFF;
    }

    .violet {
        display: none;
    }

    /* ====== Start Css đổi màu Header theo banner ====== */
    .header.active .box-header-2024,
    .header.active .box-popup-header-sub,
    .header.active .box-header-2024-mb .main-header-2024-mb.view1 {
        background: #502D6F;
    }

    .header.active .box-top .box-khcc-new a {
        color: #AFAFAF;
    }

    .header.active .box-top .box-khcc-new.active a,
    .header.active .box-menu-sub a,
    .header.active .box-popup-header-sub .box-sub2-menu .text-sub2-menu a {
        color: #FFFFFF;
    }

    .header.active .box-menu-sub.active a {
        color: #FFFFFF;
        font-weight: 500;
    }

    .header.active .box-bottom .button-login,
    .header.active .box-bottom .button-login:hover {
        background: #FFFFFF;
        box-shadow: unset;
    }

    .header.active .box-bottom .button-login span {
        color: #502D6F;
    }

    .header.active .white {
        display: none;
    }

    .header.active .violet {
        display: block;
    }

    /* ====== End Css đổi màu Header theo banner ====== */
    .main-header-2024,
    .box-popup-sub-main {
        width: 1170px;
        margin: 0 auto;
    }

    .logo-website-tpb {
        width: 170px;
        height: 39px;
    }

    .box-popup-header-sub {
        width: 100%;
        margin: 0 auto;
        padding: 35px 0;
        display: none;
        position: static;
        background: #FFF;
    }

    .box-popup-header-sub.active {
        display: flex;
    }

    .box-top .box-khcc-new {
        padding: 20px;
    }

    .box-top .box-khcc-new.active {
        position: relative;
    }

    .box-top .box-khcc-new.active::after {
        content: '';
        border: solid #D3D3D3;
        border-width: 0 1px 1px 0;
        display: inline-block;
        padding: 4px;
        position: absolute;
        -webkit-transform: rotate(45deg);
        -moz-transform: rotate(45deg);
        -ms-transform: rotate(45deg);
        -o-transform: rotate(45deg);
        transform: rotate(45deg);
        -webkit-transform: rotate(225deg);
        bottom: -5px;
        left: 35%;
        background: #FFF;
    }

    .header.active .box-top .box-khcc-new.active::after {
        content: '';
        border: solid #8D6BAB;
        border-width: 0 1px 1px 0;
        background: #502D6F;
    }

    .box-top .box-khcc-new.active a {
        color: #863ACC;
        font-weight: 500;
    }

    .box-top .box-khcc-new:first-child {
        padding-left: 0;
    }

    .box-top .box-khcc-new a {
        font-size: 16px;
        line-height: 19.2px;
        text-align: left;
        color: #AFAFAF;
    }

    .box-icon-header-new-2024 {
        position: relative;
    }

    .tooltip {
        position: absolute;
        width: max-content;
        top: 50px;
        padding: 5px 10px;
        background: #E9DBF5;
        z-index: 10;
        text-align: center;
        border-radius: 20px;
        color: #863ACC;
        visibility: hidden;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .box-icon-header-new-2024:hover .tooltip {
        visibility: visible;
        opacity: 1;
    }

    .box-bottom {
        border-top: 1px solid #D3D3D3;
    }

    .header.active .box-bottom {
        border-top: 1px solid #8D6BAB;
    }

    .box-bottom .box-menu-sub {
        padding: 20px 20px;
        flex: 0 0 auto;
    }

    .box-bottom .box-sub1-menu {
        display: none;
    }

    .box-bottom .box-sub1-menu.active {
        display: flex;
        overflow: hidden;
        white-space: nowrap;
        cursor: grab;
    }

    .box-bottom .box-menu-sub:first-child {
        padding-left: 0;
    }

    .box-menu-sub a {
        font-size: 16px;
        font-weight: 400;
        line-height: 20.8px;
        text-align: left;
        color: #6F6F6F;
    }

    .box-menu-sub a:hover {
        color: #5C278B;
    }

    .box-bottom .button-login {
        width: 137px;
        height: 50px;
        padding: 10px 30px 10px 30px;
        gap: 10px;
        border-radius: 8000px;
        background: #5C278B;
        display: flex;
        position: relative;
    }

    .box-bottom .button-login:hover {
        box-shadow: 0px 5px 10px 0px #6E4096CC inset;
        background: linear-gradient(90deg, #8444bb, #39234c);
    }

    .box-bottom .button-login span {
        padding: 5px 0px;
        font-size: 16px;
        font-weight: 500;
        line-height: 19.2px;
        color: #fff;
    }

    .box-bottom .button-login .box-login {
        position: absolute;
        top: 60px;
        left: 0;
        background: #fff;
        padding: 20px;
        width: 220px;
        border-radius: 20px;
        display: grid;
        box-shadow: 0px 15px 30px -10px #D4B3ED33;
        visibility: hidden;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .box-bottom .button-login .box-login.active {
        visibility: visible;
        opacity: 1;
    }

    .box-bottom .button-login .box-login a {
        font-size: 16px;
        font-weight: 400;
        line-height: 32px;
        text-align: left;
        color: #6F6F6F;
    }

    .box-popup-header-sub .box-sub2-menu .text-sub2-menu a {
        font-size: 16px;
        font-weight: 300;
        line-height: 20.8px;
        color: #6F6F6F;
    }

    .box-popup-header-sub .box-sub2-menu {
        display: none;
    }

    .box-popup-header-sub .box-sub2-menu.active {
        display: block;
    }

    .stOverflowAuto {
        overflow: unset !important;
    }

    #header {
        position: sticky;
        z-index: 1000 !important;
        top: 0;
        width: 100%;
        padding-bottom: 0;
    }

    .choise-lang {
        background: #FFF;
        border-radius: 8px;
        padding: 5px 10px;
        right: 0;
        width: 100px;
        border: none;
    }

    .choise-lang a {
        font-size: 16px;
        margin: 5px 0;
        font-weight: 500;
        line-height: 20.8px;
        text-align: left;
        color: #6F6F6F;
    }

    .choise-lang a:hover,
    .choise-lang a.selected {
        background-color: transparent;
        color: #5C2291;
    }

    .bạkground-tranpre {
        background: #00000080;
        position: fixed;
        width: 100vw;
        height: 100vh;
        top: 0;
        z-index: 1000 !important;
        /* backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px); */
        border-radius: 5px;
        display: none;
    }

    .box-search-popup {
        position: absolute;
        z-index: 10001;
        top: 30px;
        left: 50%;
        display: none;
        transform: translate(-50%, 5%);
    }

    .box-lang-mobile {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 80vw;
        transform: translate(-50%, -50%);
        border-radius: 8px;
        background: #FFF;
        box-shadow: 0px 10px 30px -10px #45049833;
        display: none;
    }

    .box-lang-mobile a {
        font-size: 16px;
        font-weight: 700;
        line-height: 32.8px;
        color: #6F6F6F;
        padding: 10px 20px;
    }

    .box-lang-mobile a.selected {
        color: #5C2291;
    }

    .bạkground-tranpre.active,
    .box-search-popup.active {
        display: block;
    }

    .box-lang-mobile.active {
        display: grid;
    }

    #cse-search-box-new {
        width: 900px;
        margin: 0 auto;
    }

    .input-search-box-new {
        display: flex;
        justify-content: center;
        background: #FFF;
        border-radius: 8px;
        padding: 5px 20px;
    }

    .input-search-box-new .input-search {
        width: 100%;
    }

    .search_gg {
        background: url(/wps/contenthandler/dav/themelist/custom.portal.theme.TPBThemev1/custom/images/search.png);
        background-size: 25px 25px;
        height: 22px;
        width: 25px;
    }

    .box-flast-link-header {
        display: block;
        width: 100%;
        height: 100%;
        background: #FFF;
        position: relative;
        top: 15px;
    }

    .box-flast-link-header::after {
        background-image: none;
    }

    .header-flast-link {
        font-style: unset;
        color: #5C2291;
    }

    .list-flast-link-menu {
        list-style: none;
        padding: 5px 0;
    }

    .box-list-data-detail-mb,
    .list-menu-sub1-mobile.active,
    .box-detail-sub-1-mb,
    .box-sub2-menu-mb {
        display: none;
    }

    .box-list-data-detail-mb.active,
    .box-detail-sub-1-mb.active,
    .box-sub2-menu-mb.active {
        display: block;
    }

    .box-flast-link-header .list-flast-link-menu a {
        font-size: 16px;
        font-weight: 400;
        line-height: 20.8px;
        color: #6F6F6F;
    }

    .box-list-data-detail-mb .box-detail-sub-1-mb .box-menu-sub-mb {
        border-bottom: 1px solid #F1F1F1;
        margin: 10px 0;
        padding: 5px 0;
    }

    .box-list-data-detail-mb .box-detail-sub-1-mb .box-menu-sub-mb .box-flex-sub2 {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .box-list-data-detail-mb .box-detail-sub-1-mb .box-menu-sub-mb .box-flex-sub2 a {
        color: #6F6F6F;
        font-size: 16px;
        font-weight: 400;
        line-height: 36.2px;

    }

    .box-list-data-detail-mb .box-detail-sub-1-mb .box-menu-sub-mb .box-flex-sub2 img {
        width: 12px;
        -webkit-transform: rotate(90deg);
        -moz-transform: rotate(90deg);
        -ms-transform: rotate(90deg);
        -o-transform: rotate(90deg);
        transform: rotate(90deg);
        transition: transform 0.5s ease-in-out;
    }

    .box-list-data-detail-mb .box-detail-sub-1-mb .box-title-relative {
        position: relative;
    }

    .box-list-data-detail-mb .box-detail-sub-1-mb .title-sub1-mb {
        background: #F6F1FB;
        padding: 10px 30px;
        font-size: 16px;
        font-weight: 500;
        line-height: 19.2px;
        text-align: left;
        color: #6F6F6F;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .box-list-data-detail-mb .box-detail-sub-1-mb .box-title-relative .box-toltip-title {
        display: none;
        position: absolute;
        top: 45px;
        background: #F6F1FB;
        width: 100%;
        z-index: 100;
        border-radius: 8px;
        padding: 10px 30px;
    }
    .box-list-data-detail-mb .box-detail-sub-1-mb .box-title-relative .box-toltip-title.active {
        display: grid;
    }

    .box-list-data-detail-mb .box-detail-sub-1-mb .box-title-relative .box-toltip-title a {
        font-size: 16px;
        font-weight: 500;
        line-height: 26px;
        text-align: left;
        color: #6F6F6F;
    }

    .box-list-data-detail-mb .box-detail-sub-1-mb .title-sub1-mb img {
        width: 12px;
        -webkit-transform: rotate(90deg);
        -moz-transform: rotate(90deg);
        -ms-transform: rotate(90deg);
        -o-transform: rotate(90deg);
        transform: rotate(90deg);
    }

    .box-sub2-menu-mb.active {
        padding: 10px 0;
    }

    .box-sub2-menu-mb.active .text-sub2-menu-mb a {
        color: #6F6F6F;
        font-size: 14px;
        font-weight: 300;
        padding: 5px 0;
        line-height: 24px;
    }

    .box-sub2-menu-mb.active .text-sub2-menu-mb a:hover {
        font-weight: 400;
    }

    .box-list-data-detail-mb .box-detail-sub-1-mb .box-menu-sub-mb.active .box-flex-sub2 img {
        -webkit-transform: rotate(270deg);
        -moz-transform: rotate(270deg);
        -ms-transform: rotate(270deg);
        -o-transform: rotate(270deg);
        transform: rotate(270deg);
    }

    .border-bottom-header-violet {
        border-bottom: 1px solid #8D6BAB;
    }

    .border-bottom-header-white {
        border-bottom: 1px solid #D3D3D3;
    }

    body.scolloff {
        overflow: hidden;
    }

    .dke-tk-onl-parent {
        z-index: 1000 !important;
    }

    .header .box-header-2024-mb .main-header-2024-mb.view2 {
        display: none;
    }

    .header .box-header-2024-mb .main-header-2024-mb.view1.close {
        display: none;
    }

    .header .box-header-2024-mb .main-header-2024-mb.view2.active {
        display: flex;
    }

    @media only screen and (max-width: 1200px) {
        .dke-dk-tk-onl {
            left: 90%;
            transform: translateX(-81%);
        }

        .dke-dk-triangle {
            left: 65%;
        }

        .dke-dk-triangle-bg {
