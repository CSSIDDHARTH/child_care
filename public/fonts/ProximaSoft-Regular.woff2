            hover2.style.display = "none";
        });

        hover2.addEventListener('mouseover', function () {
            clearTimeout(timeoutId);
        });*/

        $("#btOpenMenuMb").click(function () {
            $(".box-list-menu-mb").addClass("active");
            $("#content").addClass("scroll-none");
            $('#btnOpenMobile').addClass('d-none');
            $('#btnCloseMobile').removeClass('d-none');
            $('.box-bottom-menu-mobile').removeClass('d-none');
            $('.main-header-2024-mb.view1').addClass('close');
            $('.main-header-2024-mb.view2').addClass('active');
        });

        $("#btCloseMenuMb").click(function () {
            $(".box-list-menu-mb").removeClass("active");
            $("#content").removeClass("scroll-none");
            $('#btnCloseMobile').addClass('d-none');
            $('#btnOpenMobile').removeClass('d-none');
            $('.box-detail-sub-1-mb').removeClass("active");
            $('.box-menu-sub-mb').removeClass('active');
            $('.box-sub2-menu-mb').removeClass('active');
            $('#listMenuSub1Mb').removeClass('active');
            $('#boxListDataMb').removeClass('active');
            $('.box-bottom-menu-mobile').addClass('d-none');
            $('.main-header-2024-mb.view1').removeClass('close');
            $('.main-header-2024-mb.view2').removeClass('active');
        });
        $(".button-login").click(function () {
            $(".box-login").toggleClass("active");
        });

        const pathnameUrl = window.location.href;
        const checkURl = pathnameUrl.match("/eng");
        if (checkURl == null) {
            $('.langVN').addClass('selected');
        } else if (checkURl != null) {
            $('.langEN').addClass('selected');
        }

        scrollHeaderMenu('menu-header-khcn');
        scrollHeaderMenu('menu-header-khdn');

        
    });

    $(window).scroll(function () {
        var currentScroll = $(window).scrollTop();
        if (currentScroll >= 1) {
            $('#header').addClass('header-fix');
            $('#header').css({
                position: 'fixed',
                top: '0',
                'z-index': '1000'
            });
        } else {
            $('#header').removeClass('header-fix');
            $('#header').css({
                position: 'relative',
                top: '0',
                'z-index': '1000'
            });
        }
    });

    
</script>

