<style>
    #footerNew {
        float: left;
        width: 100%;
    }

    .box-footer {
        width: 1170px;
        margin: 0 auto;
    }

    .box-footer .box-list-icon {
        padding: 50px 0;
        position: relative;
        border-bottom: 1px solid #AFAFAF;
    }

    .box-footer .box-list-icon .btn-toggle-footer {
        background: linear-gradient(0deg, #863ACC, #863ACC),
            linear-gradient(90deg, rgba(250, 0, 255, 0.3) 0%, rgba(250, 0, 255, 0) 100%);
        width: 30px;
        height: 25px;
        position: absolute;
        top: 0;
        right: 0;
        border-radius: 0 0 8px 8px;
        display: grid;
        align-items: center;
        justify-content: center;
    }

    .box-footer .box-list-icon .btn-toggle-footer img {
        width: 9px;
        -webkit-transform: rotate(270deg);
        -moz-transform: rotate(270deg);
        -ms-transform: rotate(270deg);
        -o-transform: rotate(270deg);
        transform: rotate(270deg);
    }

    .box-footer .box-list-icon .btn-toggle-footer.active img {
        -webkit-transform: rotate(90deg);
        -moz-transform: rotate(90deg);
        -ms-transform: rotate(90deg);
        -o-transform: rotate(90deg);
        transform: rotate(90deg);
    }

    .box-footer .box-list-icon .box-btn-icon-footer {
