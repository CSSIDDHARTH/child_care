<script>
 $(".dke-tk-onl-parent").click(function (evt) {
        var target = evt.target.className;
        var inside = "dke-tk-onl-parent";
        if ($.trim(target) != '') {
            if (target == inside) {
                $('body').removeClass('scolloff')
                $(this).css("display", "none");
            }
        }
    });
    $(window).resize(function () {
        const windWidth = $(window).innerWidth();
        if (windWidth <= 987) {
            $('body').removeClass('scolloff')
            $('.dke-tk-onl-parent').css("display", "none");
        }
    });

</script>

