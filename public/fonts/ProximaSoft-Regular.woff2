            }

            .thought {
                display: none;
                background-color: #fe9901;
                padding: 20px;
                border-radius: 30px;
                width: 160px;
                min-height: 40px;
                margin: 20px;
                position: absolute;
                right: -17px;
                top: -110px;
                color: #FFFFFF;
                align-items: center;
                justify-content: center;
                text-align: center;
                box-sizing: unset;
            }

            .thought a {
                color: #FFFFFF;
            }

            p.thought:before {
                content: ' ';
                position: absolute;
                width: 0;
                height: 0;
            }

            p.thought:before {
                right: 40px;
                bottom: -16px;
                border: 8px solid;
                border-color: #fe9901 #fe9901 transparent transparent;
            }

            .btn-on-top {
                display: none;
            }

            .hoverVR:hover~.thought {
                display: block;
            }

            @media (max-width: 590px) {
                .btn-on-top {
                    display: block;
                    position: fixed;
                    right: 18px;
                    bottom: 125px;
                    z-index: 200;
                }

                #btnOnTop {
                    background: #E9DBF5;
                    border-radius: 50%;
                    cursor: pointer;
                    display: block;
                    height: 46px;
                    width: 46px;
                    color: #fff;
                    text-align: center;
                    line-height: 49px;
                }

                #btnOnTop .sz22 {
                    font-size: 20px;
                    font-weight: normal;
                    font-stretch: normal;
                    font-style: normal;
                    line-height: 1.25;
                    letter-spacing: normal;
                    text-align: left;
                    color: #000;
                    text-align: center;
                }

                #meta-bot-vr {
                    bottom: 230px;
                }
            }

            @media (max-width: 475px) {
                #meta-bot-vr {
                    bottom: 180px;
                }
            }

            @media (max-width: 425px) {
                #meta-bot-vr {
                    width: 100%;
                }

                .thought {
                    width: 40%;
                }

                #meta-bot-vr a {
                    position: absolute;
                    right: 0;
                }
                #meta-bot-vr {
                    bottom: 230px;
                }
            }
        </style>

        <a href="https://meta.tpb.vn/"  class="hoverVR"><img
                src="/wps/contenthandler/dav/themelist/custom.portal.theme.TPBThemev1/custom/images/TPmascot.png"
                alt="metaVR" style="width: 65px; height: 60px;"></a>
        <p id="thoughtChat" class="thought">
            <a href="https://meta.tpb.vn/" >Triển lãm “Tiên phong hành trình SỐ”</a>
        </p>
    </div>
    <div id="chat-bot-fb"></div>
    <div class="btn-on-top">
        <a id="btnOnTop"><i class="fa fa-angle-up sz22"></i></a>
    </div>
    <script>
        /*Back To Top*/
        $('#btnOnTop').click(function () {
            $('html, body').stop().animate({
                'scrollTop': 0
            }, 1000, 'swing');
        });

        var url = window.location.href;
        if (url.search("ban-dau-gia-tai-san") != -1) {
            var html = `<div class="fb-customerchat" page_id="309417446580023" logged_in_greeting="Xin chào! Mình là Trợ lý ảo T’Aio của TPBank. Mình có thể giúp gì cho bạn?" logged_out_greeting="Xin chào! Mình là Trợ lý ảo T’Aio của TPBank. Mình có thể giúp gì cho bạn?" theme_color="#F58220">
 </div>`;
        } else {
            var html = `<div class="fb-customerchat" page_id="309417446580023" logged_in_greeting="Xin chào! Mình là Trợ lý ảo T’Aio của TPBank. Mình có thể giúp gì cho bạn?" logged_out_greeting="Xin chào! Mình là Trợ lý ảo T’Aio của TPBank. Mình có thể giúp gì cho bạn?" theme_color="#F58220">`
        }
        $('#chat-bot-fb').html(html);
        $('.stOverflowAuto').addClass('unset');

        // function addClassthoughtChat() {
        //     $("#thoughtChat").addClass("active");
        // }
        // setTimeout(addClassthoughtChat, 2000);

        // function removeThoughtChat() {
        //     $("#thoughtChat").removeClass("active");
        // }

        var pathFooter = '';
        $(".box-danh-sach-sp .box-detail-footer-list").each(function () {
            pathFooter = $(this).attr("path");
            var idFooter = $(this)[0].children[1].id;
            var fullPath = "/wps/wcm/connect" + pathFooter + "?source=library&srv=cmpnt&cmpntid=3e1c96b2-456b-4b71-8b7a-17b1c849a279";
            $.ajax({
                type: "GET",
                url: fullPath,
                //async: false,
                success: function (text) {
                    $('#' + idFooter).append(text);
                }
            });
        });
        const btnCloseFooter = document.querySelector('.btn-toggle-footer');
        btnCloseFooter.addEventListener('click', () => {
            const closeFooter = document.querySelector('.box-list-detail-footer');
            closeFooter.classList.toggle('active');
            btnCloseFooter.classList.toggle('active');
        });

        $(".box-icon-plus-minus").click(function () {
            const id = $(this).data("id");
            $('#footer-' + id).toggleClass('active');
            $(this).find('.img-icon-plus-footer').toggleClass('close');
            $(this).find('.img-icon-minus-footer').toggleClass('open');
        });

        $(".box-icon-plus-minus-contact").click(function () {
            $('.list-btn-contact').toggleClass('active');
            $(this).find('.img-icon-plus-contact-footer').toggleClass('close');
            $(this).find('.img-icon-minus-contact-footer').toggleClass('open');
        });

    </script>
</div>

</div>

                        
                    
                
                
            
        
    

    
        





        







    
