    .dke-border-y {
        margin: 5px 0 0 0;
        padding: 0;
        background-color: #5E2E86;
        height: 111px;
        box-shadow: 0px 4px 4px rgba(0, 0, 0, 0.25);
        opacity: 0.5;
        width: 1px;
