    .dke-dktk-item p {
        color: #7A7D9A;
        font-size: 12px;
        font-weight: normal;
        margin: 0;
        line-height: 14px;
    }

    .dke-dktk-item:last-child h2 {
        padding: 0 25px
    }

    .dke-dktk-item:last-child p {
        padding: 0 16px !important;
    }

    .dke-tk-mb {
        text-align: center !important;
        margin-top: 18px;
    }

    .dke-tk-mb img {
        margin-right: 6px;
    }

    .dke-dkol-mb {
        cursor: pointer;
        font-size: 16px ;
        font-weight: normal !important;
        color: #FFFFFF !important;
        text-decoration: none !important;
        border-bottom: 1px solid #FFFFFF !important;
        border-radius: unset !important;
        padding: 0 0 4px 0 !important;
        background: unset !important;
    }

    @media only screen and (max-width: 1200px) {
        .dke-dk-tk-onl {
            left: 90%;
            transform: translateX(-81%);
        }

        .dke-dk-triangle {
            left: 65%;
        }

        .dke-dk-triangle-bg {
            right: 121px;
        }
    }

    /* chỉnh sửa màn 1025px */
    @media only screen and (max-width: 1025px) {
        .sub-nice-menu-inner {
            position: absolute;
            right: 45%;
        }

    }
