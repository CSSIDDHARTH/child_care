<script>
    var arrayColor = [
{
"colorMultiple": "#EDEEF2$#0000001a"
}
]
;

    function findDataColorHeader() {
        arrayColor.forEach((items, index) => {
            if (items.colorMultiple.includes('$')) {
                const colors = items.colorMultiple.split('$');
                $('#header')[0].style.boxShadow = `0px 15px 30px 0px ${colors[1]}`;
            }
        });
    }

    function fetchAllParallel(elements, getUrlCallback) {
		const promises = [];
		elements.each(function(index, el) {
			const url = getUrlCallback($(this));
			if (url) {
				const request = fetch(url).then(async(res)=> {
                    const data = await res.text();
					return { index: index, html: data, element: el };
				});
				promises.push(request);
			}
		});
		return Promise.all(promises);
	}
    const listBoxTop = $(".box-top .box-khcc-new");
    if (listBoxTop.length > 0) {
        fetchAllParallel(listBoxTop, function(el) {
            const path = el.attr("path");
            return "/wps/wcm/connect" + path + "?source=library&srv=cmpnt&cmpntid=b909735e-ab90-4c5d-9cd2-fc624f0c12ca";
        }).then(function(results) {
            results.sort((a, b) => a.index - b.index);
            const finalHtml = results.map(r => r.html).join('');
            $('#boxSub1Menu').append(finalHtml);
            const listBoxBottom = $(".box-bottom .box-menu-sub");
            fetchAllParallel(listBoxBottom, function(el) {
                const path = el.attr("path");
                return "/wps/wcm/connect" + path + "?source=library&srv=cmpnt&cmpntid=178118e1-95fc-4699-ba35-4fdfbf85c9c0";
            }).then(function(results) {
                results.sort((a, b) => a.index - b.index);
                const finalHtml = results.map(r => r.html).join('');
                $('#mainSub2Menu').append(finalHtml);
                menuHover();
            })
        })

    }
    const listBoxTopMb = $(".box-top .box-khcc-new");
    if (listBoxTopMb.length > 0) {
        fetchAllParallel(listBoxTopMb, function(el) {
            const path = el.attr("path");
            return "/wps/wcm/connect" + path + "?source=library&srv=cmpnt&cmpntid=8e401aef-d4b3-4bf8-bb52-736de863f513";
        }).then(function(results) {
            results.sort((a, b) => a.index - b.index);
            const finalHtml = results.map(r => r.html).join('');
            $('#boxListDataMb').append(finalHtml);
            const listSubMb = $("#boxListDataMb .box-menu-sub-mb");
            if (listSubMb.length > 0) {
                const promises4 = [];
                listSubMb.each(function() {
                    const path = $(this).attr("path");
                    const targetId = $(this).data("id"); // Dùng .data('id') thay vì dataset
                    const url = "/wps/wcm/connect" + path + "?source=library&srv=cmpnt&cmpntid=4c0a5da9-1b59-4dd2-930d-02a63a9b533b";
                    const req = fetch(url).then(async(res) => {
                        $('#' + targetId).append(await res.text());
                    });
                    promises4.push(req);
                });
            }
        });
    }
    //06012025
    // $(".box-top .box-khcc-new").each(function () {
    //     const path1 = $(this).attr("path");
    //     var fullPath = "/wps/wcm/connect" + path1 + "?source=library&srv=cmpnt&cmpntid=b909735e-ab90-4c5d-9cd2-fc624f0c12ca";
