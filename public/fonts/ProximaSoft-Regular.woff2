<style>
    
    body.scolloff {
        overflow: hidden;
    }

    .dke-tk-onl-parent {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        display: none;
        overflow: auto;
        height: 100%;
        z-index: 9;
        background: rgba(67, 35, 100, 0.8);
        backdrop-filter: blur(5px);
    }

    .dke-dk-tk-onl {
        position: absolute;
        width: 475px;
        border-radius: 10px;
        top: 106px;
        left: 58%;
        box-shadow: 0px 3px 10px rgb(0 0 0 / 25%);
        background: #FFFFFF;
    }

    .dke-dk-triangle {
        position: absolute;
        width: 0;
        height: 0;
        border-left: 22px solid transparent;
        border-right: 22px solid transparent;
        border-bottom: 14px solid #7B35BB;
        right: 160px;
        top: -12px;
        z-index: 2;
    }

    .dke-dk-triangle-bg {
        position: absolute;
        width: 0;
        height: 0;
        border-left: 22px solid transparent;
        border-right: 22px solid transparent;
        border-bottom: 14px solid #FFFFFF;
        right: 160px;
        top: -14px;
    }

    .dke-tk-onl-head {
        background: #7B35BB;
        border-radius: 10px 10px 0 0;
        position: relative;
        margin: 1px;
    }

    .dke-tk-onl-head p {
        color: #FFFFFF;
        font-weight: bold;
        font-size: 26px;
        line-height: 67px;
        text-align: center;
        margin: 0;
    }

    .dke-tk-onl-step {
        display: grid;
        grid-template-columns: 1fr 0 1fr;
        grid-row-gap: 12px;
        position: relative;
        text-align: center;
        padding-top: 34px;
    }

    .dke-dk-img-step {
        position: absolute;
        left: 50%;
        top: 55%;
        transform: translate(-50%, 0);
        height: 23px;
        background-color: #ffffff;
    }

    .dke-dk-line {
        height: 110px;
        width: 1px;
        opacity: 0.5;
        background-color: rgba(52, 52, 65, 0.3);
        ;
        box-shadow: 0px 4px 4px rgba(0, 0, 0, 0.25);
    }

    .dke-dk-img-step img {
        margin-top: 4px;
    }

    .dke-tk-onl-step span {
        width: 100%;
        text-align: center;
    }

    .dke-tk-step .dke-tk-step-a {
        display: inline-block;
        font-size: 16px;
        color: #7B35BB;
        width: 106px;
        line-height: 36px;
        background-color: #FFFFFF;
        border-radius: 16px;
        font-weight: bold;
        border: 1px solid #7B35BB;
    }

    .dke-tk-step .dke-tk-step-a.active {
        color: #FFFFFF;
        background-color: #7B35BB;
        ;
    }


    .dke-tk-onl-step p {
        text-align: center;
        font-size: 14px;
        color: #7A7D9A;
        font-weight: normal;
        line-height: 18px;
        margin: 9px 0 0 0;
    }

    .dke-tk-onl-body {
        padding: 0 21px;
        padding-bottom: 30px;
    }

    .dke-tk-onl-body p.title-qr-code {
        margin: 25px 0 22px 0;
        font-size: 16px;
        font-weight: bold;
        text-align: center;
        color: #7B35BB;
        ;
