    .dke-tk-onl-body .dke-tk-title {
        margin: 27px 0 27px 0;
    }

    .dke-dktk-items {
        display: grid;
        grid-template-columns: 1fr 0.4px 168px 0.4px 1fr;
    }

    .dke-img-qr-code {
        text-align: center;
        border-bottom: 1px solid #5E2E86;
        padding-bottom: 30px;
    }

    .dke-dktk-item {
        text-align: center;
    }

    .dke-dktk-item:first-child {
        padding: 0 32px 0 16px;
    }


    .dke-dktk-item:last-child {
        border: unset;
    }

    .dke-dktk-item img {
        width: 86px;
        height: 82px;
    }

    .dke-dktk-item p.subtitle-qr-code {
