    function openPopupSearch() {
        $('body').addClass('scolloff');
        $(".bạkground-tranpre").addClass('active');
        $(".box-search-popup").addClass('active');
    };
    function openPopupLang() {
        $('body').addClass('scolloff');
        $(".bạkground-tranpre").addClass('active');
        $(".box-lang-mobile").addClass('active');
    };

    var modal = document.getElementById('backgroundClick');
    // var modal1 = document.getElementsByClassName('dke-tk-onl-parent');

    function openMenuSub2Mobile(id, text) {
        if ($('#mb-' + id).length != 0) {
            $('.box-detail-sub-1-mb').removeClass('active');
            $('#boxListDataMb').addClass('active');
            $('#mb-' + id).addClass('active');
            // $('.title-sub1-mb').text(text);
            $('#listMenuSub1Mb').addClass('active');
            $('.box-toltip-title').removeClass('active');
        }
    }

    $('.box-detail-sub-1-mb .box-title-relative .title-sub1-mb').click(function () {
        var keyCheckActive = $('.box-detail-sub-1-mb.active .box-title-relative .box-toltip-title')[0].classList.contains('active');
        if (keyCheckActive == true) { 
            $('.box-toltip-title').removeClass('active');
        } else {
            $('.box-toltip-title').addClass('active');
        }
    });

    function openMenuSub3Mobile(id) {
        var keyCheckActive = $('#mb-sub3-' + id)[0].classList.contains('active');
        if (keyCheckActive == true) {
            $('.box-menu-sub-mb').removeClass('active');
            $('.box-sub2-menu-mb').removeClass('active');
            $('#mb-' + id).removeClass('active');
        } else {
            $('.box-menu-sub-mb').removeClass('active');
            $('.box-sub2-menu-mb').removeClass('active');
            $('#mb-sub3-' + id).addClass('active');
            $('#mb-' + id).addClass('active');
        }

    }

    $('.category-box-detail-item-dktk').click(function () {
        $('.dke-tk-onl-parent').css("display", "block");
        $('body').addClass('scolloff')
    });

    window.onclick = function (event) {
        if (event.target == modal) {
            $('body').removeClass('scolloff');
            $(".bạkground-tranpre").removeClass('active');
            $(".box-search-popup").removeClass('active');
            $(".box-lang-mobile").removeClass('active');
        }
    };

    function scrollHeaderMenu(id) {
        let headerIsDown = false;
        let headerStartX;
        let headerScrollLeft;

        const menuHeader = document.querySelector('#' + id);
        if(menuHeader == undefined) {
            return
        }

        menuHeader.addEventListener('mousedown', (e) => {
            headerIsDown = true;
            headerStartX = e.pageX - menuHeader.offsetLeft;
            headerScrollLeft = menuHeader.scrollLeft;
        });

        menuHeader.addEventListener('mouseleave', () => {
            headerIsDown = false;
        });

        menuHeader.addEventListener('mouseup', () => {
            headerIsDown = false;
        });

        menuHeader.addEventListener('mousemove', (e) => {
            if (!headerIsDown) return; // Nếu không đang kéo thì thoát
            e.preventDefault(); // Ngăn chặn sự kiện mặc định
            const x = e.pageX - menuHeader.offsetLeft;
            const walk = (x - headerStartX) * 2; // Điều chỉnh tốc độ kéo
            menuHeader.scrollLeft = headerScrollLeft - walk; // Cập nhật scrollLeft
        });
    };

    function menuHover(){
    	findDataColorHeader();
    	if(window.location.pathname.includes('/doanh-nghiep')){
    		$("#main-menu-header-khdn").addClass("active");
        	$("#menu-header-khdn").addClass("active");	
    	}
    	else{
    		$("#main-menu-header-khcn").addClass("active");
        	$("#menu-header-khcn").addClass("active");	
    	}
        
        $(".box-top .box-khcc-new").hover(function (e) {
            $(".box-top .box-khcc-new").removeClass("active");
            $(".box-bottom .box-sub1-menu").removeClass("active");
            $(this).addClass("active");
            let nametag = $(this).attr('nametag');
            $("#" + nametag).addClass("active");
        });
        let hoverKeyActive;
        const hover1Element = document.querySelectorAll('.box-menu-sub');
        const hover2 = document.querySelector('.box-popup-header-sub');
        let timeoutId;
        $(".box-bottom .box-sub1-menu .box-menu-sub").hover(function (e) {
            $(".box-bottom .box-sub1-menu .box-menu-sub").removeClass("active");
            $(".box-popup-header-sub .box-sub2-menu").removeClass("active");
            $(this).toggleClass("active");
            var id = $(this)[0].dataset.id;
            hoverKeyActive = $("#" + id + ".box-sub2-menu").length;
            if (hoverKeyActive == 0) {
                hover2.style.display = "none";
            } else {
                hover2.style.display = "flex";
            }
            $("#" + id + ".box-sub2-menu").toggleClass("active");
        });

        hover1Element.forEach(hover1 => {
            hover1.addEventListener('mouseover', function () {
                clearTimeout(timeoutId);
                $(".box-popup-header-sub").addClass("active");
            });

            hover1.addEventListener('mouseout', function () {
                timeoutId = setTimeout(function () {
                    if (!hover2.matches(':hover')) {
                        $(".box-popup-header-sub").removeClass("active");
                        hover2.style.display = "none";
                    }
                }, 150);
            });
        })

        hover2.addEventListener('mouseleave', function () {
            $(".box-popup-header-sub").removeClass("active");
            hover2.style.display = "none";
        });

        hover2.addEventListener('mouseover', function () {
            clearTimeout(timeoutId);
        });
    }

    $(document).ready(function () {
        /*findDataColorHeader();
        $("#main-menu-header-khcn").addClass("active");
        $("#menu-header-khcn").addClass("active");

        $(".box-top .box-khcc-new").hover(function (e) {
