                hover2.style.display = "none";
            } else {
                hover2.style.display = "flex";
            }
            $("#" + id + ".box-sub2-menu").toggleClass("active");
        });

        hover1Element.forEach(hover1 => {
            hover1.addEventListener('mouseover', function () {
                clearTimeout(timeoutId);
                $(".box-popup-header-sub").addClass("active");
            });

            hover1.addEventListener('mouseout', function () {
